DJANGO_DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgres://user:password@host:5432/dbname
ALLOWED_HOSTS=your-backend.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
FRONTEND_BASE_URL=https://your-frontend.vercel.app
SITE_BASE_URL=https://your-backend.onrender.com
ENABLE_API_DOCS=False
ALLOW_DEBUG_AUTH_HEADERS=False
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_WEBHOOK_SECRET=sk_live_xxx
PAYSTACK_CALLBACK_URL=https://your-frontend.vercel.app/checkout/success
FIREBASE_CREDENTIALS_FILE=/absolute/path/to/serviceAccountKey.json
# Or for deployment platforms, paste the full JSON into FIREBASE_CREDENTIALS.
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}
OTP_TOTP_ISSUER=Kbee Admin
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Kbee Computers <no-reply@example.com>
